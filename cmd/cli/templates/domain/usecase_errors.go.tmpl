package {{.DomainNameSnake}}

import (
	"errors"
	"strings"

	{{.DomainNameCamel}}domain "{{.ModulePath}}/internal/domain/{{.DomainNameSnake}}"
	ucshared "{{.ModulePath}}/internal/usecases/shared"
	"{{.ModulePath}}/pkg/apperror"
)

// expectedErrors per use case — consumed by ucshared.ClassifyError to decide
// whether an error is a business-flow warning (WarnSpan with a semantic
// attribute) or an infra failure (FailSpan with error.type + stack trace).
//
// Attribute keys come from the shared set in internal/usecases/shared/attrkeys.go
// so that every domain in the codebase — including domains generated by
// `gopherplate new` / `gopherplate add domain` — uses the same semantic keys
// (app.result, app.validation_error). See docs/guides/observability.md and
// docs/guides/error-handling.md.
var (
	createExpectedErrors = []ucshared.ExpectedError{
		{Err: {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}DuplicateKey, AttrKey: ucshared.AttrKeyAppResult, AttrValue: "duplicate_key"},
	}
	getExpectedErrors = []ucshared.ExpectedError{
		{Err: {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound, AttrKey: ucshared.AttrKeyAppResult, AttrValue: "not_found"},
	}
	updateExpectedErrors = []ucshared.ExpectedError{
		{Err: {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound, AttrKey: ucshared.AttrKeyAppResult, AttrValue: "not_found"},
	}
	deleteExpectedErrors = []ucshared.ExpectedError{
		{Err: {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound, AttrKey: ucshared.AttrKeyAppResult, AttrValue: "not_found"},
	}
	// listExpectedErrors is intentionally nil — list only produces infra errors.
)

// {{.DomainNameCamel}}ToAppError maps domain errors to structured AppError codes.
func {{.DomainNameCamel}}ToAppError(err error) *apperror.AppError {
	switch {
	case errors.Is(err, {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound):
		return apperror.Wrap(err, apperror.CodeNotFound, "{{.DomainNameSnake}} not found")
	case errors.Is(err, {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}DuplicateKey):
		return apperror.Wrap(err, apperror.CodeConflict, "{{.DomainNameSnake}} already exists")
	case isParseError(err):
		return apperror.Wrap(err, apperror.CodeInvalidRequest, "invalid ID")
	default:
		return apperror.Wrap(err, apperror.CodeInternalError, "internal server error")
	}
}

// isParseError detects UUID/ID parse errors from uuid.Parse.
func isParseError(err error) bool {
	return strings.Contains(err.Error(), "invalid UUID")
}
