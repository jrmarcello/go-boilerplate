# Copie este arquivo para .env e ajuste os valores

# Servidor
SERVER_PORT=8080

# Postgres (usado pelo docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=people
POSTGRES_PORT=5432

# Aplicação (opcional)
DB_DSN=postgres://user:password@localhost:5432/people?sslmode=disable

# Cache (opcional)
REDIS_URL=redis://localhost:6379
REDIS_TTL=5m
REDIS_ENABLED=true
REDIS_PORT=6379

# Observabilidade (opcional)
OTEL_SERVICE_NAME=people-service-registry
OTEL_COLLECTOR_URL=
