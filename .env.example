# Servidor
SERVER_PORT=8080

# Postgres (Writer)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=entities

# Postgres Reader (opcional - para DB cluster com read replicas)
# DB_READER_DSN=postgres://user:password@reader-host:5432/entities?sslmode=disable

# Postgres Pool (opcional)
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=5m

# Redis (Cache)
REDIS_URL=redis://localhost:6379
REDIS_TTL=5m
REDIS_ENABLED=true
REDIS_PORT=6379

# Swagger (opcional)
SWAGGER_ENABLED=true

# Observabilidade (opcional)
OTEL_SERVICE_NAME=entity-service
OTEL_COLLECTOR_URL=

# Autenticação (opcional)
# SERVICE_KEY=
